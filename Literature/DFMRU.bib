  volume = {39},
  number = {1},
  pages = {18--36},
  issn = {1099-131X},
  doi = {10.1002/for.2602},
  abstract = {We assess the predictive content of latent economic policy uncertainty and data surprise factors for forecasting and nowcasting GDP using factor-type econometric models on five emerging market economies (Brazil, Indonesia, Mexico, South Africa, Turkey). The set of models includes simple benchmark linear models and dynamic factor models estimated via frequentist and Bayesian LASSO-type shrinkage methods. The authors find that the inclusion of new uncertainty and surprise factors leads to superior predictions of GDP growth, particularly when these latent factors are constructed using Bayesian variants of the LASSO. To avoid seasonal-adjustment-induced bias, the authors construct year-on-year growth rates of input series and link a partially observed monthly YoY GDP series via a Mariano-Murasawa-style restriction.}
